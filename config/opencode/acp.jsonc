{
    "$schema": "https://raw.githubusercontent.com/ranxianglei/opencode-acp/master/dcp.schema.json",
    "compress": {
        "maxContextLimit": "65%",
        "minContextLimit": "55%",
        "nudgeFrequency": 15,
        "nudgeForce": "soft"
    },
    "gc": {
        "batchCleanup": {
            "lowThreshold": "70%",
            "highThreshold": "85%"
        }
    }
}
